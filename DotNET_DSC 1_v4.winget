  ########################################################################
  # Registry: Edge Extension whitelisting and forced install
  ########################################################################
    - resource: "xPSDesiredStateConfiguration/xRegistry"
      directives:
        description: "Block all extensions"
      settings:
        Key: "HKLM:\\Software\\Policies\\Microsoft\\Edge\\ExtensionInstallBlocklist"
        ValueName: "1"
        ValueData: "*"
        ValueType: "String"    #String (REG_SZ) | Binary (REG_BINARY)| DWord (REG_DWORD) | QWord (REG_QWORD)| MultiString (REG_MULTI_SZ) | ExpandString (REG_EXPAND_SZ) 
        Force: true
        Ensure: "Present"
    - resource: "xPSDesiredStateConfiguration/xRegistry"
      directives:
        description: "Allow Edge extension 'Vue.js devtools'"
      settings:
        Key: "HKLM:\\Software\\Policies\\Microsoft\\Edge\\ExtensionInstallAllowlist"
        ValueName: "1"
        ValueData: "nhdogjmejiglipccpnnnanhbledajbpd"
        ValueType: "String"    #String (REG_SZ) | Binary (REG_BINARY)| DWord (REG_DWORD) | QWord (REG_QWORD)| MultiString (REG_MULTI_SZ) | ExpandString (REG_EXPAND_SZ) 
        Force: true
        Ensure: "Present"
    - resource: "xPSDesiredStateConfiguration/xRegistry"
      directives:
        description: "Force install extension 'Vue.js'"
      settings:
        Key: "HKLM:\\Software\\Policies\\Microsoft\\Edge\\ExtensionInstallForcelist"
        ValueName: "1"
        ValueData: "nhdogjmejiglipccpnnnanhbledajbpd"
        ValueType: "String"    #String (REG_SZ) | Binary (REG_BINARY)| DWord (REG_DWORD) | QWord (REG_QWORD)| MultiString (REG_MULTI_SZ) | ExpandString (REG_EXPAND_SZ) 
        Force: true
        Ensure: "Present"
  ########################################################################
  # Settings: Modify Hosts file
  ########################################################################
    - resource: NetworkingDsc/HostsFile
      directives:
        description: add/removes entries in hosts file
      settings:
        HostName: localhost
        IPAddress: 127.0.0.1
        Ensure: Present
