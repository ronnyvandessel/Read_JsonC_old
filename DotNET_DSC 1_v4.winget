      settings:
        id: Chocolatey.Chocolatey
        source: winget
  ########################################################################
  # Choco: Install Oracle SQL Developer
  ########################################################################
    - resource: Chocolatey/ChocolateyPackage
      id: ChocoOracleSQLDeveloper
      dependsOn:
        - choco
      directives:
        description: Install Oracle SQL Developer
      settings:
        Name: oracle-sql-developer
        Ensure: Present
  ########################################################################
  # Choco: Install DotPeek
  ########################################################################
    - resource: Chocolatey/ChocolateyPackage
      id: DotPeek
      dependsOn:
        - choco
      directives:
        description: Install DotPeek
      settings:
        Ensure: Present
        Name: dotpeek
        ChocolateyOptions:
          packageParameters: "/PerMachine"
  ########################################################################
  # Choco: Install DotPeek
  ########################################################################
    - resource: Chocolatey/ChocolateyPackage
      id: ReSharper
      dependsOn:
        - choco
      directives:
        description: Install ReSharper
      settings:
        Ensure: Present
        Name: resharper
        ChocolateyOptions:
          packageParameters: "/PerMachine"
  ########################################################################
  # Winget: Install DotTrace
  ########################################################################
    - resource: Chocolatey/ChocolateyPackage
      id: DotTrace
      dependsOn:
        - choco
      directives:
        description: Install JetBrains dotTrace
      settings:
        Ensure: Present
        Name: dottrace
        ChocolateyOptions:
          packageParameters: "/PerMachine"
  ########################################################################
  # Choco: Install sqlcmd utility
  ########################################################################
    - resource: Chocolatey/ChocolateyPackage
      id: sqlcmd
      dependsOn:
        - choco
      directives:
        description: Install sqlcmd utility
      settings:
        Ensure: Present
        Name: sqlcmd
  ########################################################################
  # Powershell: Create c:\DEVS\DOTNET\scratch
  ########################################################################
    - resource: PSDscResources/Script
      id: CreateDEVSfolder
      directives:
        description: Creates c:\DEVS folder structure
      settings:
        GetScript: |
          # not needed
        TestScript: |
          If(Test-Path -Path c:\DEVS\DOTNET\scratch){return $true} else {return $false}
        SetScript: |
          New-Item -Path c:\DEVS\DOTNET\scratch -ItemType Directory -Force
