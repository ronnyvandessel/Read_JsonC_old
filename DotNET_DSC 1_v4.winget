# yaml-language-server: $schema=https://aka.ms/configuration-dsc-schema/0.2
properties:
  resources:
  ########################################################################
  # Windows Optional Features: Enable NetFx3
  ########################################################################
#    - resource: PSDscResources/WindowsOptionalFeature   #doesn't work, 'class not registered' error, https://github.com/microsoft/winget-cli/issues/4264#issuecomment-1992369583
#      directives:
#        description: Enable NetFx3
#      settings:
#        Ensure: present # [Present, Absent]
#        Name: NetFx3
    - resource: PSDscResources/Script
      id: NetFx3
      directives:
        description: Enable optional Windows feature .NET Framework 3.5
      settings:
        GetScript: |
          return $true
        TestScript: |
          $output = dism.exe /online /get-featureinfo /featurename:NetFx3
          if ($output -match 'State : Enabled') {return $true}
          else {return $false}
        SetScript: |
          dism.exe /online /enable-feature /featurename:NetFx3 /all /norestart
  ########################################################################
  # Windows Optional Features: Enable IIS
  ########################################################################
    - resource: PSDscResources/Script
      id: IIS
      dependsOn:
         - NetFx3
      directives:
        description: Enable IIS
      settings:
        GetScript: |
          return $true
        TestScript: |
          $output = dism.exe /online /get-featureinfo /featurename:Web-Server
          if ($output -match 'State : Enabled') {return $true}
          else {return $false}
        SetScript: |
          dism.exe /online /enable-feature /featurename:Web-Server /all /norestart
  ########################################################################
  # Windows Settings: Enable Developer Mode
  ########################################################################
  #  - resource: Microsoft.Windows.Developer/DeveloperMode
  #    directives:
  #      description: Enable Developer Mode
  #      allowPrerelease: true
  #    settings:
  #      Ensure: Present
  ########################################################################
  # Winget: Install .NET Framework 
  ########################################################################
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: .NETframework
      directives:
        description: Install .NET Framework 
      settings:
        id: Microsoft.DotNet.Framework.DeveloperPack_4
        source: winget
  ########################################################################
  # Powershell: Source Code Signing with KBC Key
  ########################################################################
    - resource: PSDscResources/Script
      id: SourceCodeSigning
      dependsOn:
         - .NETframework
      directives:
        description: Source Code Signing with KBC Key
      settings:
        GetScript: |
          # not needed
        TestScript: |
          $result = @()
          Get-ChildItem "C:\Program Files (x86)\Microsoft SDKs\Windows\v*.*\bin\NETFX *.*.* Tools\sn.exe" | ForEach-Object {$result += & $_ -Vl}
          if ($result -notcontains "No verification entries registered") {return $true} else {return $false}
        SetScript: |
          Get-ChildItem "C:\Program Files (x86)\Microsoft SDKs\Windows\v*.*\bin\NETFX *.*.* Tools\sn.exe" | ForEach-Object {& $_ -Vr *,edc51795076b6be9}
  ########################################################################
  # Winget: Install NuGet
  ########################################################################
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: NuGet
      directives:
        description: Install NuGet
      settings:
        id: Microsoft.NuGet
        source: winget
