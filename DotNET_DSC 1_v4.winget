  ########################################################################
  # Registry: VSCode Extension whitelisting
  ########################################################################
    - resource: "xPSDesiredStateConfiguration/xRegistry"
      directives:
        description: "enforced whitelisting of VSCode extensions"
      settings:
        Key: "HKLM:\\Software\\Policies\\Microsoft\\VSCode"
        ValueName: "AllowedExtensions"
        ValueData: ['vue.volar','dbaeumer.vscode-eslint','esbenp.prettier-vscode','Lokalise.i18n-ally','octref.vetur']
        ValueType: "MultiString"    #String | Binary | DWord | QWord | MultiString | ExpandString 
        Force: true
        Ensure: "Present"
  ########################################################################
  # Winget: Install Atlassion Sourcetree
  ########################################################################
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Sourcetree
      directives:
        description: Install Atlassian Sourcetree
      settings:
        id: Atlassian.Sourcetree
        source: winget
  ########################################################################
